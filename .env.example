# OpenAI
OPENAI_API_KEY=
MODEL=gpt-5.4-mini

# Local runtime
DB_PATH=data/kiribati_monitor.sqlite
OUTPUT_DIR=output
SITE_DIR=site
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=20
HTTP_MAX_ATTEMPTS=3
HTTP_BACKOFF_SECONDS=1.0
REQUIRE_EMAIL=false

# Optional email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
